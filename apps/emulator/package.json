{
  "name": "@farcaster/snap-emulator",
  "private": true,
  "scripts": {
    "build": "next build --webpack",
    "build:workspace-deps": "pnpm --filter @farcaster/snap run build",
    "clean": "rm -rf .next",
    "prebuild": "pnpm run build:workspace-deps",
    "predev": "pnpm run build:workspace-deps",
    "dev": "next dev -p 3000 --webpack",
    "start": "next start -p 3000",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@base-ui/react": "1.0.0",
    "@farcaster/jfs": "0.2.2",
    "@farcaster/snap": "workspace:*",
    "@json-render/core": "^0.15.0",
    "@json-render/react": "^0.15.0",
    "@neynar/ui": "^1.2.2",
    "@noble/curves": "2.0.1",
    "lucide-react": "^1.7.0",
    "next": "^16.2.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tw-animate-css": "^1.4.0",
    "viem": "^2.21.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3"
  }
}
