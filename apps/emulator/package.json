{
  "name": "@farcaster/snap-emulator",
  "private": true,
  "scripts": {
    "build": "next build --webpack",
    "build:workspace-deps": "pnpm --filter @farcaster/snap --filter @farcaster/snap-ui-elements run build",
    "clean": "rm -rf .next",
    "prebuild": "pnpm run build:workspace-deps",
    "predev": "pnpm run build:workspace-deps",
    "dev": "next dev -p 3000 --webpack",
    "start": "next start -p 3000",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@farcaster/jfs": "0.2.2",
    "@farcaster/snap": "workspace:*",
    "@farcaster/snap-ui-elements": "workspace:*",
    "@json-render/core": "^0.15.0",
    "@json-render/react": "^0.15.0",
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@next/mdx": "^16.2.1",
    "@noble/curves": "2.0.1",
    "@types/mdx": "^2.0.13",
    "lucide-react": "^1.7.0",
    "next": "^16.2.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "remark-gfm": "^4.0.1",
    "viem": "^2.21.0",
    "zod": "^3.25.0 || ^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "typescript": "^5.9.3"
  }
}
