{
  "name": "shared-games",
  "version": "1.0.0",
  "description": "Shared Games — collaborative games in the Farcaster feed",
  "scripts": {
    "predev": "pnpm --filter @farcaster/snap run build",
    "dev": "tsx watch src/server.ts",
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^1.0.0",
    "hono": "^4.0.0",
    "@farcaster/snap": "workspace:*",
    "@farcaster/snap-hono": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.0.0",
    "typescript": "^5.9.3"
  }
}
