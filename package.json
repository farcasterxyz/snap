{
  "name": "snap",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "pnpm": {
    "overrides": {
      "esbuild": "^0.25.0"
    }
  },
  "scripts": {
    "build": "turbo build",
    "changeset:prepublish": "pnpm --filter './pkgs/*' build",
    "changeset:publish": "pnpm changeset:prepublish && changeset publish",
    "changeset:version": "pnpm install --lockfile-only && changeset version && pnpm typecheck",
    "clean": "pnpm run -r --parallel clean",
    "dev": "turbo dev",
    "preinstall": "npx only-allow pnpm",
    "test": "turbo test",
    "typecheck": "turbo typecheck"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.1",
    "@changesets/cli": "^2.29.8",
    "only-allow": "^1.2.1",
    "turbo": "^2.4.4"
  }
}
